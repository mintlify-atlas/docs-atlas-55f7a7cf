  "keyFeatures": [
    "Multiple professional resume templates (Classic, Modern, Minimal)",
    "Real-time live preview of resume changes",
    "Comprehensive resume sections (Personal Info, Experience, Education, Skills, Projects, Custom Sections)",
    "Drag-and-drop section reordering",
    "Mobile-first responsive design with floating preview",
    "Auto-save to browser localStorage",
    "PDF export via browser print functionality",
    "Import/Export resume data as JSON",
    "Dark mode UI for comfortable editing"
  ],
  "publicApiSurface": [
    "useResume() - Main context hook for resume state management",
    "ResumeProvider - Context provider component",
    "ResumeData - Type definition for resume data structure",
    "PersonalInfo - Type for personal information",
    "Experience - Type for work experience entries",
    "Education - Type for education entries",
    "Skill - Type for skills",
    "Project - Type for projects",
    "CustomSection - Type for custom sections",
    "ResumeTemplate - Type for template selection ('classic' | 'modern' | 'minimal')",
    "updatePersonalInfo() - Update personal information fields",
    "updateSummary() - Update professional summary",
    "addExperience() / updateExperience() / removeExperience() - Manage experience entries",
    "addEducation() / updateEducation() / removeEducation() - Manage education entries",
    "addSkill() / removeSkill() - Manage skills",
    "addProject() / updateProject() / removeProject() - Manage projects",
    "addCustomSection() / updateCustomSection() / removeCustomSection() - Manage custom sections",
    "reorderSections() - Change section display order"
  ]
}
